#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const { loadConfig, getPromptsDir, validateConfig } = require("../lib/config");
const { createRunDir, readMeta } = require("../lib/run");
const { runPlanStage, runStage, continueWorkflow, retryFailedAgents } = require("../lib/workflow");

const USER_DIR = process.env.AICOUNCIL_HOME || process.cwd();
const CONFIG_PATH = path.join(USER_DIR, "council.yaml");
const RUNS_DIR = path.join(USER_DIR, "runs");

function resolveRunDir(arg) {
  if (arg === "--latest") {
    const latest = require("../lib/run").latestRunDir(RUNS_DIR);
    if (!latest) { console.log("No runs found."); process.exit(1); }
    return latest;
  }
  return arg;
}

function printHelp() {
  console.log(`aicouncil — Multi-agent AI dev council orchestrator

Usage:
  aicouncil plan <topic>          Generate independent plans from all agents
                [--file <path>]    Read additional context from a file
                [--stdin]          Read topic from stdin
                [--skip <agents>]  Comma-separated agents to skip
  aicouncil continue <run-dir|--latest>  Continue a run
  aicouncil retry <run-dir|--latest>    Retry failed agents in a run
                --agent <name>     Retry only this agent
  aicouncil status <run-dir|--latest>   Show run status
  aicouncil init                  Create council.yaml template in current directory
  aicouncil health                Probe all agents for availability
  aicouncil update                 Update aicouncil CLI to latest version
  aicouncil help                  Show this help

Options:
  --dry-run    Print commands without executing
  --verbose    Print full prompts and agent output
`);
}

function cmdInit() {
  const target = path.join(process.cwd(), "council.yaml");
  if (fs.existsSync(target)) {
    console.log(`council.yaml already exists at ${target}`);
    process.exit(1);
  }

  const templatePath = path.join(__dirname, "..", "init-template.yaml");
  const template = fs.readFileSync(templatePath, "utf-8");

  fs.writeFileSync(target, template);
  console.log(`Created: ${target}`);

  // Copy built-in prompt templates
  const builtinPrompts = path.join(__dirname, "..", "prompts");
  const localPrompts = path.join(process.cwd(), "prompts");
  if (fs.existsSync(builtinPrompts) && !fs.existsSync(localPrompts)) {
    fs.mkdirSync(localPrompts, { recursive: true });
    for (const f of fs.readdirSync(builtinPrompts)) {
      if (f.endsWith(".md")) {
        fs.copyFileSync(path.join(builtinPrompts, f), path.join(localPrompts, f));
      }
    }
    console.log(`Copied prompts to: ${localPrompts}`);
  }

  // Add runs/ to .gitignore
  const gitignore = path.join(process.cwd(), ".gitignore");
  if (fs.existsSync(gitignore)) {
    const content = fs.readFileSync(gitignore, "utf-8");
    if (!content.includes("runs/")) {
      fs.appendFileSync(gitignore, "\nruns/\n");
      console.log("Added runs/ to .gitignore");
    }
  }

  console.log("Edit council.yaml to configure your agents and workflow.");
}

function cmdStatus(runDir) {
  const meta = readMeta(runDir);
  console.log(JSON.stringify(meta, null, 2));
}

function cmdValidate() {
  try {
    const config = loadConfig(CONFIG_PATH);
    const errors = validateConfig(config);
    if (errors.length === 0) {
      console.log("Configuration is valid.");
      console.log(`Agents: ${Object.keys(config.agents).join(", ")}`);
      console.log(`Stages: ${config.workflow.stages.map(s => s.id).join(" → ")}`);
    } else {
      console.log("Configuration errors:");
      errors.forEach(e => console.log(`  - ${e}`));
      process.exit(1);
    }
  } catch (err) {
    console.log(`Error: ${err.message}`);
    process.exit(1);
  }
}

async function cmdHealth(config) {
  console.log("Agent health check:\n");
  for (const [name, agent] of Object.entries(config.agents)) {
    if (!agent.command) {
      console.log(`  [${name}] orchestrator (no command)`);
      continue;
    }
    try {
      const result = await require("../lib/agent").runAgent(agent.command, [...(agent.args || []), "--version"], "", 10000);
      if (result.ok && result.stdout) {
        const firstLine = result.stdout.split("\n")[0].slice(0, 60);
        console.log(`  [${name}] OK — ${firstLine}`);
      } else {
        console.log(`  [${name}] FAIL — ${result.stderr?.split("\n")[0]?.slice(0, 60) || `exit ${result.exitCode}`}`);
      }
    } catch (e) {
      console.log(`  [${name}] FAIL — ${e.message}`);
    }
  }
}

async function main() {
  const args = process.argv.slice(2);

  // Global flags
  const dryRun = args.includes("--dry-run");
  const verbose = args.includes("--verbose");
  const stdinMode = args.includes("--stdin");
  const fileIdx = args.indexOf("--file");
  const filePath = fileIdx !== -1 && fileIdx + 1 < args.length && !args[fileIdx + 1].startsWith("--") ? args[fileIdx + 1] : null;
  const skipAgents = [];
  const skipIndices = new Set();
  for (let i = 0; i < args.length; i++) {
    if (args[i] === "--skip" && i + 1 < args.length) {
      const names = args[i + 1].split(",").map(s => s.trim()).filter(Boolean);
      skipAgents.push(...names);
      skipIndices.add(i);
      skipIndices.add(i + 1);
      i++;
    }
  }
  const filteredArgs = args.filter((a, i) => {
    if (a === "--dry-run" || a === "--verbose" || a === "--stdin") return false;
    if (a === "--file" || a === "--skip") return false;
    if (filePath && i === fileIdx + 1) return false;
    if (skipIndices.has(i)) return false;
    return true;
  });

  if (dryRun) console.log("[DRY RUN] No commands will be executed.\n");
  if (verbose) process.env.AICOUNCIL_VERBOSE = "1";

  const cmd = filteredArgs[0];

  switch (cmd) {
    case "plan": {
      let topic = filteredArgs.slice(1).join(" ");

      if (stdinMode) {
        topic = fs.readFileSync(0, "utf-8").trim();
      }

      if (filePath) {
        if (!fs.existsSync(filePath)) {
          console.log(`File not found: ${filePath}`);
          process.exit(1);
        }
        const fileContent = fs.readFileSync(filePath, "utf-8").trim();
        topic = topic ? `${topic}\n\n---\n\n${fileContent}` : fileContent;
      }

      if (!topic) { console.log("Usage: aicouncil plan <topic> [--file <path>] [--stdin]"); process.exit(1); }
      if (dryRun) { console.log(`Would run: plan (${topic.length} chars)`); break; }
      const config = loadConfig(CONFIG_PATH);
      const promptsDir = getPromptsDir(CONFIG_PATH);
      const { dir, name } = createRunDir(RUNS_DIR, topic);
      console.log(`\nRun: ${name}\nDir:  ${dir}\n`);
      fs.writeFileSync(path.join(dir, "00_input.md"), topic.trim() + "\n");
      const meta = { id: name, createdAt: new Date().toISOString(), stage: "planning_running", topic: topic.slice(0, 200), agents: {} };
      require("../lib/run").writeMeta(dir, meta);
      await runPlanStage(config, promptsDir, dir, topic, skipAgents);
      meta.stage = "planning_done";
      require("../lib/run").writeMeta(dir, meta);
      console.log(`\nOutput: ${dir}`);
      console.log(`\nNext files to create in the run directory:\n  03_opencode_architect.md   (your plan)\n  04_synthesis.md             (compare all plans)\n  05_questions_for_human.md   (decisions needed)\n  06_human_answers.md         (after human responds)\n  07_final_plan.md            (v1 plan)\n\nThen: aicouncil continue ${dir}`);
      break;
    }
    case "continue": {
      let dir = resolveRunDir(filteredArgs[1]);
      if (!dir) { console.log("Usage: aicouncil continue <run-dir|--latest>"); process.exit(1); }
      if (dryRun) { console.log(`Would run: continue ${dir}`); break; }
      const config = loadConfig(CONFIG_PATH);
      const promptsDir = getPromptsDir(CONFIG_PATH);
      await continueWorkflow(config, promptsDir, dir, skipAgents);
      break;
    }
    case "retry": {
      let dir = resolveRunDir(filteredArgs[1]);
      if (!dir) { console.log("Usage: aicouncil retry <run-dir|--latest> [--agent <name>]"); process.exit(1); }
      const retryAgent = args.includes("--agent") ? args[args.indexOf("--agent") + 1] : null;
      if (dryRun) { console.log(`Would retry ${retryAgent || "all failed"} in ${dir}`); break; }
      const config = loadConfig(CONFIG_PATH);
      const promptsDir = getPromptsDir(CONFIG_PATH);
      await retryFailedAgents(config, promptsDir, dir, retryAgent);
      break;
    }
    case "status": {
      let dir = resolveRunDir(filteredArgs[1]);
      if (!dir) { console.log("Usage: aicouncil status <run-dir|--latest>"); process.exit(1); }
      cmdStatus(dir);
      break;
    }
    case "update": {
      const installDir = path.resolve(__dirname, "..");
      console.log(`Updating aicouncil in ${installDir}...`);
      const { execSync } = require("child_process");
      try {
        console.log(execSync("git pull", { cwd: installDir, encoding: "utf-8" }).trim());
        execSync("npm install --silent", { cwd: installDir });
        console.log("CLI updated. Updating skill...");
        execSync("npx skills update aic -g -y", { stdio: "inherit" });
        console.log("Done. Restart your AI tool to load the updated skill.");
      } catch (e) {
        console.log("Update failed:", e.message);
      }
      break;
    }
    case "doctor": {
      const config = loadConfig(CONFIG_PATH);
      const errors = validateConfig(config);
      if (errors.length > 0) {
        console.log("Config errors:");
        errors.forEach(e => console.log(`  - ${e}`));
      } else {
        console.log("Config: valid");
      }
      await cmdHealth(config);
      break;
    }
    case "init":
      cmdInit();
      break;
    case "run": {
      const stage = filteredArgs[1];
      const dir = filteredArgs[2];
      if (!stage || !dir) { console.log("Usage: aicouncil run <stage> <run-dir>"); process.exit(1); }
      if (dryRun) { console.log(`Would run: stage "${stage}" on ${dir}`); break; }
      const config = loadConfig(CONFIG_PATH);
      const promptsDir = getPromptsDir(CONFIG_PATH);
      await runStage(config, promptsDir, dir, stage);
      break;
    }
    case "validate":
      cmdValidate();
      break;
    case "version":
    case "--version":
    case "-v":
      console.log(require("../package.json").version);
      break;
    case "help":
    case "--help":
    case "-h":
      printHelp();
      break;
    default:
      console.log(`Unknown command: ${cmd}`);
      printHelp();
      process.exit(1);
  }
}

main().catch((err) => {
  console.error("Fatal:", err.message);
  process.exit(1);
});
